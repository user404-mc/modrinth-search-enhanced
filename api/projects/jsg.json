et=\"_blank\" style=\"text-decoration:none\" rel=\"nofollow\">\n        <strong><p style=\"font-family:monospace;text-align:center\">Additional Origins</p></strong>\n      </a>\n    </th>\n    <th>\n      <a href=\"https://modrinth.com/resourcepack/jsg-sd\" target=\"_blank\" style=\"text-decoration:none\" rel=\"nofollow\">\n        <strong><p style=\"font-family:monospace;text-align:center\">SD resource pack</p></strong>\n      </a>\n    </th>\n    <th>\n      <a href=\"https://modrinth.com/resourcepack/jsg-sample\" target=\"_blank\" style=\"text-decoration:none\" rel=\"nofollow\">\n        <strong><p style=\"font-family:monospace;text-align:center\">Sample resource pack</p></strong>\n      </a>\n    </th>\n    <th>\n      <a href=\"https://modrinth.com/mod/rsj\" target=\"_blank\" style=\"text-decoration:none\" rel=\"nofollow\">\n        <strong><p style=\"font-family:monospace;text-align:center\">Redstone Jukeboxes</p></strong>\n      </a>\n    </th>\n  </tr>\n</table>",
