om OptiFine?</h2>\n\n<table>\n  <tbody>\n    <tr>\n      <td>🔍 Zoom</td>\n      <td>✅ Included</td>\n    </tr>\n    <tr>\n      <td>🌅 Shaders</td>\n      <td>✅ Included</td>\n    </tr>\n    <tr>\n      <td>💡 Dynamic Lights</td>\n      <td>✅ Included</td>\n    </tr>\n    <tr>\n      <td>🍃 Smart Leaves</td>\n      <td>✅ Included</td>\n    </tr>\n    <tr>\n      <td>🦸 Capes</td>\n      <td>✅ Included</td>\n    </tr>\n    <tr>\n      <td>⚙️ Advanced Video Settings</td>\n      <td>✅ Included</td>\n    </tr>\n    <tr>\n      <td>📸 HD Screenshots</td>\n      <td>✅ Included</td>\n    </tr>\n  </tbody>\n</table>\n\n<hr>\n\n<h2>🎨 Resource Pack Features</h2>\n\n<table>\n  <tbody>\n    <tr>\n      <td>🖼️ Animated Textures</td>\n      <td>🔗 Connected Textures</td>\n    </tr>\n    <tr>\n      <td>🔳 Custom GUI</td>\n      <td>🪙 Custom Items</td>\n    </tr>\n    <tr>\n      <td>☁️ Custom Sky</td>\n      <td>🅰️ HD Fonts</td>\n    </tr>\n    <tr>\n      <td>🎲 Random Entities</td>\n      <td>📐 Custom Entity Models</td>\n    </tr>\n    <tr>\n      <td>🌈 Custom Colors</td>\n      <td>🚀 Splash Screen Support</td>\n    </tr>\n    <tr>\n      <td>🔍 Anisotropic Filtering</td>\n      <td>📷 HD Screenshots</td>\n    </tr>\n  </tbody>\n</table>\n\n<hr>\n\n<h2>💬 Community & Support</h2>\n\n<p>\n  Need help, want to report a bug, or follow updates? Join the Discord community.\n</p>\n\n<p align=\"center\">\n  <a href=\"https://discord.gg/a2fhAY8wnQ\" target=\"_blank\" rel=\"nofollow noopener\">\n    <img src=\"https://img.shields.io/badge/Join-Discord-blue?style=for-the-badge&amp;logo=discord\" alt=\"Join Discord\">\n  </a>\n</p>\n\n<hr>\n\n<p align=\"center\">\n  <a href=\"https://billing.sparkedhost.com/aff.php?aff=2774\" target=\"_blank\" rel=\"nofollow noopener\">\n    <img src=\"https://imgur.com/71IXfzh.png\" alt=\"Hosting\">\n  </a>\n</p>",
